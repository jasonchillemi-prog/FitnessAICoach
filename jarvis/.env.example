# Jarvis environment configuration
# Copy this file to jarvis/.env and fill in your values.
# jarvis/.env is gitignored — never commit real keys.

# ── AI Provider ────────────────────────────────────────────────────────
# Set to one of: anthropic | openai | google
# If PROVIDER is not set, defaults to anthropic.
PROVIDER=anthropic

# ── API Keys (only the one matching PROVIDER is required) ──────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GOOGLE_API_KEY=your-google-ai-key-here

# ── Optional: override model without editing CONFIG.json ───────────────
# MODEL=claude-sonnet-4-6
