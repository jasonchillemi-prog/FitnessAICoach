{
  "expo": {
    "name": "KineticIQ",
    "slug": "FitnessAICoach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kineticiq.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in quickly and securely.",
        "NSCalendarsUsageDescription": "KineticIQ adds your workout and meal schedule to your calendar.",
        "NSRemindersUsageDescription": "KineticIQ sets reminders for your meals and workouts.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.kineticiq.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-calendar",
      "expo-local-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "bf6df862-ab4c-47c9-b0d1-39fdc2c7ce45"
      }
    }
  }
}
